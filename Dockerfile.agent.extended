FROM node:20-slim

# Step 1: Build MemoryCore
WORKDIR /TrustCore-MemoryCore
COPY TrustCore-MemoryCore/package.json TrustCore-MemoryCore/package-lock.json* ./
RUN npm ci
COPY TrustCore-MemoryCore/src/ ./src/
COPY TrustCore-MemoryCore/tsconfig.json ./
RUN npm run build

# Step 2: Build ASBCP TypeScript SDK
WORKDIR /TrustCore-ASBCP/ASBCP-Agent-Schema-Based-Communication-Protocol/sdk-typescript
COPY TrustCore-ASBCP/ASBCP-Agent-Schema-Based-Communication-Protocol/sdk-typescript/package.json \
     TrustCore-ASBCP/ASBCP-Agent-Schema-Based-Communication-Protocol/sdk-typescript/package-lock.json* ./
RUN npm ci
COPY TrustCore-ASBCP/ASBCP-Agent-Schema-Based-Communication-Protocol/sdk-typescript/src/ ./src/
COPY TrustCore-ASBCP/ASBCP-Agent-Schema-Based-Communication-Protocol/sdk-typescript/tsconfig.json ./
RUN npm run build

# Step 3: Build Engine
WORKDIR /app
COPY TrustCore-Engine/package.json TrustCore-Engine/package-lock.json* ./
RUN npm ci --omit=dev

COPY TrustCore-Engine/tsconfig.json ./
COPY TrustCore-Engine/src/ ./src/

RUN npm install ts-node typescript @types/node @types/pg

ENV NODE_ENV=production
ARG AGENT_MODE=mcp
ENV AGENT_MODE=${AGENT_MODE}

CMD ["node", "--loader", "ts-node/esm", "src/index.ts"]
