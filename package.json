{
  "name": "trustcore-engine",
  "version": "0.1.0",
  "description": "Locally-hosted, always-on AI agent framework with persistent memory and sub-agent orchestration",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "node --loader ts-node/esm src/index.ts",
    "dev:alex": "node --loader ts-node/esm src/index.ts alex",
    "dev:research": "node --loader ts-node/esm src/index.ts research",
    "dev:api": "node --loader ts-node/esm src/index.ts api",
    "dev:email-writer": "node --loader ts-node/esm src/index.ts email-writer",
    "test:memory": "node --loader ts-node/esm scripts/test-memory.ts",
    "test:integration": "node --loader ts-node/esm scripts/integration-test.ts",
    "test:eval": "node --loader ts-node/esm scripts/test-eval.ts",
    "test": "npm run test:memory && npm run test:integration",
    "migrate": "bash scripts/migrate.sh",
    "seed": "psql $DATABASE_URL -f db/seed.sql",
    "db:seed": "npm run migrate && npm run seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "ingest": "node --loader ts-node/esm src/scripts/ingest.ts"
  },
  "keywords": [
    "ai-agent",
    "local-first",
    "persistent-memory",
    "orchestration",
    "mcp"
  ],
  "author": "TrustCore Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/pg": "^8.20.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/express": "^5.0.6",
    "@types/ws": "^8.18.1",
    "express": "^5.2.1",
    "pg": "^8.11.3",
    "pgvector": "^0.2.1",
    "ws": "^8.19.0",
    "zod": "^3.22.4"
  }
}
