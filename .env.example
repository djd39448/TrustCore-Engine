# TrustCore Engine — Environment Configuration
# Copy to .env and configure for your local environment

# PostgreSQL Database
POSTGRES_USER=trustcore
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=trustcore_memory
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_URL=postgresql://trustcore:changeme_in_production@localhost:5432/trustcore_memory

# Ollama (local LLM server)
OLLAMA_HOST=http://localhost:11434
DEFAULT_LLM_MODEL=llama2

# Embedding Model (for vectors)
EMBEDDING_MODEL=nomic-embed-text

# System Identity
SYSTEM_AGENT_ID=system
ALEX_AGENT_ID=alex

# Node environment
NODE_ENV=development
